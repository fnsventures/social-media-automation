{
  "name": "social-media-automation",
  "version": "1.0.0",
  "description": "Cross-post content to Facebook, Instagram, X, and YouTube via GitHub Actions",
  "type": "module",
  "scripts": {
    "publish": "node scripts/publish.js",
    "publish:dry-run": "DRY_RUN=true node scripts/publish.js",
