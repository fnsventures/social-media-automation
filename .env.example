# Copy to .env for local testing. In GitHub, add these as Repository Secrets.

# --- Meta (Facebook + Instagram) ---
# 1. Create app at https://developers.facebook.com/
# 2. Add Facebook Login; set redirect URI: http://localhost:8766/oauth/callback
# 3. Fill META_APP_ID + META_APP_SECRET, then run: npm run setup:meta
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- X (Twitter) ---
# 1. Create app at https://developer.x.com/ (Read and Write permissions)
# 2. OAuth 1.0a callback: http://localhost:8767/callback
# 3. Keys and tokens → Consumer Keys → API Key + API Key Secret (NOT OAuth 2.0 Client ID)
# 4. Add to .env, then run: npm run setup:twitter
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- YouTube ---
# 1. Enable YouTube Data API v3 at https://console.cloud.google.com/
# 2. OAuth Desktop client (or Web + redirect http://localhost:8765/oauth2callback)
# 3. Add YOUTUBE_CLIENT_ID + YOUTUBE_CLIENT_SECRET, then run: npm run setup:youtube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Content generation ---
# Caption provider:
#   local  = free template caption (default)
#   gemini = AI caption (free text tier at https://aistudio.google.com/apikey)
# Image provider (IMAGE_PROVIDER):
#   pollinations = free AI photos — get key at https://enter.pollinations.ai (recommended)
#   huggingface  = free monthly credits — token at https://huggingface.co/settings/tokens
#   local        = branded SVG/JPG template
#   gemini       = paid Gemini image models
GENERATION_PROVIDER=local
IMAGE_PROVIDER=pollinations
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
POLLINATIONS_API_KEY=
POLLINATIONS_MODEL=flux
HF_TOKEN=
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# --- Behavior ---
DRY_RUN=false
CONTENT_DIR=content/posts
TIMEZONE=Asia/Kolkata
