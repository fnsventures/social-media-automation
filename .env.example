# Copy to .env for local testing. In GitHub, add posting credentials as Repository Secrets.

# --- Meta (Facebook + Instagram) ---
# Setup: create app at https://developers.facebook.com/
# Add Facebook Login with redirect URI: http://localhost:8766/oauth/callback
# Fill META_APP_ID + META_APP_SECRET, then run: npm run setup:meta
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# --- YouTube ---
# Setup: create OAuth credentials at https://console.cloud.google.com/
# Enable YouTube Data API v3, then run: npm run setup:youtube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
# Optional: for YouTube Community image posts (not video uploads). Run: npm run setup:youtube-cookies
YOUTUBE_CHANNEL_ID=
YOUTUBE_COOKIES_JSON=

# --- WhatsApp Status ---
# Business phone that posts status updates (+91 96689 13299 → 919668913299)
# Run: npm run setup:whatsapp (enter pairing code on that phone)
# For GitHub Actions, also add WHATSAPP_AUTH_B64 (tar -czf - whatsapp-auth | base64)
WHATSAPP_AUTH_DIR=whatsapp-auth
WHATSAPP_AUTH_B64=
WHATSAPP_BUSINESS_NUMBER=919668913299
WHATSAPP_STATUS_AUDIENCE=all_contacts
# Optional: comma-separated viewers when WHATSAPP_STATUS_AUDIENCE=contacts
WHATSAPP_STATUS_CONTACTS=

# --- Google Business Profile ---
# Setup: request API access, enable Business Profile APIs, then run: npm run setup:google-business
# Can reuse YOUTUBE_CLIENT_ID / YOUTUBE_CLIENT_SECRET from the same Google Cloud project.
GOOGLE_BUSINESS_CLIENT_ID=
GOOGLE_BUSINESS_CLIENT_SECRET=
GOOGLE_BUSINESS_REFRESH_TOKEN=
GOOGLE_BUSINESS_LOCATION_NAME=
# Public URL prefix for media/ files (required for image posts). Example:
# https://raw.githubusercontent.com/owner/repo/master
GOOGLE_BUSINESS_MEDIA_BASE_URL=
GOOGLE_BUSINESS_LANGUAGE_CODE=en-IN

# --- Behavior ---
DRY_RUN=false
CONTENT_DIR=content/posts
